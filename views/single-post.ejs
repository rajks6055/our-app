<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> - OurApp</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="min-h-screen flex flex-col font-sans bg-white">
  
  <main class="flex-grow max-w-4xl w-full mx-auto pt-10 px-6">
    <div class="flex justify-between items-start mb-6">
      
      <div>
        <h2 class="text-3xl font-normal text-slate-800"><%= post.title %></h2>
        <p class="text-sm text-slate-500 mt-2">
          <img class="w-5 h-5 rounded-full inline-block mr-1 border border-slate-300" src="https://gravatar.com/avatar/placeholder?s=128&d=identicon">
          Posted by <a href="/profile/<%= post.author.username %>" class="text-blue-600 hover:underline"><%= post.author.username %></a> 
          on <%= post.createdDate.toLocaleDateString() %>
        </p>
      </div>

      <div class="flex gap-3">
        <a href="/post/<%= post._id %>/edit" class="text-blue-500 hover:text-blue-700 transition-colors" title="Edit">
          <i class="fas fa-edit"></i>
        </a>
        <form action="/post/<%= post._id %>/delete" method="POST" class="inline m-0">
          <button type="submit" class="text-red-500 hover:text-red-700 transition-colors" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </form>
      </div>

    </div>

    <div class="text-slate-700 leading-relaxed mt-8">
      <p><%= post.body %></p>
    </div>
  </main>

  </body>
</html>