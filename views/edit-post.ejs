<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Post | OurApp</title>
  <!-- Tailwind & FontAwesome for styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
</head>
<body class="bg-gray-900 text-gray-200">

  <!-- Simple Navbar -->
  <header class="bg-gray-800 border-b border-gray-700 p-4 shadow-sm">
    <div class="container mx-auto flex justify-between items-center max-w-4xl">
      <a href="/" class="text-xl font-bold text-white hover:text-blue-400 transition-colors">OurApp</a>
      <div class="flex items-center gap-4">
        <a href="/profile/<%= user.username %>" class="text-sm font-bold text-blue-400 hover:text-blue-300">My Profile</a>
        <a href="/" class="text-sm text-gray-400 hover:text-white">Cancel Edit</a>
      </div>
    </div>
  </header>

  <!-- Edit Form Area -->
  <div class="container mx-auto max-w-2xl py-8 mt-10">
    <h2 class="text-2xl font-bold mb-6 text-white">Edit Post</h2>

    <form action="/post/<%= post._id %>/edit" method="POST" class="bg-gray-800 p-6 rounded-lg shadow-md border border-gray-700">
      
      <div class="mb-4">
        <label for="post-title" class="block text-gray-400 font-bold mb-2 text-sm">Title</label>
        <input value="<%= post.title %>" name="title" id="post-title" class="w-full px-4 py-2 bg-gray-900 border border-gray-600 rounded text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors" type="text" autocomplete="off" required>
      </div>

      <div class="mb-6">
        <label for="post-body" class="block text-gray-400 font-bold mb-2 text-sm">Body Content</label>
        <textarea name="body" id="post-body" class="w-full px-4 py-2 bg-gray-900 border border-gray-600 rounded text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors h-40" required><%= post.body %></textarea>
      </div>

      <button class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 px-6 rounded transition-colors w-full sm:w-auto shadow-sm">
        Save Updates
      </button>
    </form>
  </div>

</body>
</html>