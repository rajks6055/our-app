<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Create Post - OurApp</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="min-h-screen flex flex-col font-sans bg-white">
  
  <header class="bg-slate-900 text-white py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold tracking-tight text-white"><a href="/">OurApp</a></h1>
      <div class="flex items-center gap-4">
        <button class="text-white hover:text-slate-300"><i class="fas fa-search text-lg"></i></button>
        <button class="text-white hover:text-slate-300"><i class="fas fa-comment text-lg"></i></button>
        <a href="/profile/myprofile" class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center hover:bg-blue-500"><i class="fas fa-user text-sm text-white"></i></a>
        <a href="/create-post" class="bg-green-600 hover:bg-green-500 text-white px-4 py-1.5 rounded-md text-sm font-medium">Create Post</a>
        <form action="/logout" method="POST" class="inline m-0">
          <button type="submit" class="bg-slate-500 hover:bg-slate-400 text-white px-4 py-1.5 rounded-md text-sm font-medium">Sign Out</button>
        </form>
      </div>
    </div>
  </header>

  <main class="flex-grow max-w-3xl w-full mx-auto pt-10 px-6">
    <form action="/create-post" method="POST" class="space-y-6">
      <div>
        <label for="title" class="block text-sm text-slate-500 mb-1">Title</label>
        <input type="text" name="title" id="title" class="w-full px-3 py-2 border border-slate-200 rounded outline-none focus:border-blue-400" autocomplete="off">
      </div>
      <div>
        <label for="body" class="block text-sm text-slate-500 mb-1">Body Content</label>
        <textarea name="body" id="body" rows="10" class="w-full px-3 py-2 border border-slate-200 rounded outline-none focus:border-blue-400 resize-none"></textarea>
      </div>
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded text-sm font-medium">Save New Post</button>
    </form>
  </main>

  <footer class="py-8 text-center text-slate-400 text-sm border-t border-slate-100 mt-auto">
    <p>Copyright © 2026 OurApp. All rights reserved.</p>
  </footer>
</body>
</html>