<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OurApp</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex flex-col font-sans bg-slate-50">
  
  <header class="bg-slate-900 text-white py-4 px-6 md:px-12 shadow-md">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <h1 class="text-2xl font-bold tracking-tight text-white cursor-pointer">OurApp</h1>
      
      <form action="/login" method="POST" class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
        <input type="text" name="username" placeholder="Username" class="px-3 py-1.5 rounded-md bg-slate-800 border border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 text-white">
        <input type="password" name="password" placeholder="Password" class="px-3 py-1.5 rounded-md bg-slate-800 border border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 text-white">
        <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-1.5 rounded-md text-sm font-medium">Sign In</button>
      </form>
    </div>
  </header>

  <main class="flex-grow flex items-center py-16 px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <div class="space-y-6 text-center md:text-left">
        <h2 class="text-4xl md:text-5xl font-light text-slate-900 tracking-tight">Remember Writing?</h2>
        <p class="text-lg md:text-xl text-slate-500 leading-relaxed font-light">
          Are you sick of short tweets and impersonal "shared" posts? We believe getting back to actually writing is the key to enjoying the internet again.
        </p>
      </div>

      <div class="bg-white p-8 rounded-2xl shadow-xl border border-slate-100">
        <form action="/register" method="POST" class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-1.5" for="reg-username">Username</label>
            <input id="reg-username" name="username" type="text" placeholder="Pick a username" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 outline-none bg-slate-50">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-1.5" for="reg-email">Email</label>
            <input id="reg-email" name="email" type="email" placeholder="you@example.com" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 outline-none bg-slate-50">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-1.5" for="reg-password">Password</label>
            <input id="reg-password" name="password" type="password" placeholder="Create a password" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 outline-none bg-slate-50">
          </div>
          <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-3 rounded-lg mt-2">Sign up for OurApp</button>
        </form>
      </div>

    </div>
  </main>
</body>
</html>